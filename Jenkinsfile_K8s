pipeline {
    agent any

    triggers {
      githubPush()
    }
    options {
      buildDiscarder logRotator(numToKeepStr: '5')
      timeout(time: 10, unit: 'MINUTES')
      disableConcurrentBuilds()
    }
    
    environment {
        AWS_REGION = "ap-south-1"
        EKS_CLUSTER_NAME = "eks-demo"
        IMAGE_REGISTRY_ENDPOINT = "559056419894.dkr.ecr.ap-south-1.amazonaws.com"
        IMAGE_REPOSITORY_NAME = "student-reg-webapp"
        IMAGE_REGISTRY = "${IMAGE_REGISTRY_ENDPOINT}/${IMAGE_REPOSITORY_NAME}"
        TRIVY_CACHE_DIR = "${WORKSPACE}/.trivycache"
        TMPDIR = "${WORKSPACE}/.trivytmp"
    }

    tools {
        maven 'Maven-3.9.14'
    }

    stages {

      stage("Checkout Code"){
           steps {
               git branch: 'development', credentialsId: 'c', url: 'https://github.com/Rushi-Technologies/student-reg-webapp.git'
           }
       }

      stage("Run Unit Tests"){
           steps {
               sh "mvn clean test"
           }
       } 



      stage("Maven Clean Package"){
           steps {
               sh "mvn clean package"
           }
       }
       
       stage("Sonar Scan") {
           
           steps {
               withSonarQubeEnv("SonarQube"){
                   sh '''
                        mvn sonar:sonar
                   '''
               }
           }
       }
       
       stage("WaitForQualityGateResult"){
           
          steps {
              script {
                  timeout(time: 10, unit: 'MINUTES'){
                      def qg = waitForQualityGate()
                      if  (qg.status != 'OK') {
                          error "Pipline aborted due to Failing SonarQube Qualtity Gate ${qg.status}"
                      }
                  }
              }
              
          }
       }
       
       stage("Build Docker Image"){
           steps {
               sh "docker build -t ${IMAGE_REGISTRY}:$BUILD_NUMBER ."
           }
       }
       
        stage(" Scan Docker Image"){
           steps {
                sh "mkdir -p ${TRIVY_CACHE_DIR} || true"
                sh "mkdir -p ${TMPDIR} || true"
                sh "trivy image --cache-dir ${TRIVY_CACHE_DIR} --severity HIGH,CRITICAL ${IMAGE_REGISTRY}:$BUILD_NUMBER"
           }
       }
       
       stage("Push Docker Image to ECR"){
           steps {
               sh """
               aws ecr get-login-password --region ${AWS_REGION} | docker login --username AWS --password-stdin ${IMAGE_REGISTRY_ENDPOINT}
               docker push ${IMAGE_REGISTRY}:$BUILD_NUMBER
               """
           }
       }
       
      stage('Update image tag in OPS repo (K8s)') {
        steps {
            withCredentials([usernamePassword(
            credentialsId: 'GitHubCred',
            usernameVariable: 'GIT_USER',
            passwordVariable: 'GIT_TOKEN'
            )]) {
                
                 sh '''
                    set -e

                    OPS_DIR="ops-repo"
                    OPS_REPO="https://${GIT_USER}:${GIT_TOKEN}@github.com/Rushi-Technologies/student-reg-webapp-gitops.git"

                    rm -rf "$OPS_DIR"
                    git clone "$OPS_REPO" "$OPS_DIR"
                ''' 

                dir('ops-repo') {
                    sh '''
                    set -e

                    FILE="k8s_files/deployment.yaml"
                    sed -i "s|image: \\(.*student-reg-webapp:\\).*|image: \\1${BUILD_NUMBER}|" $FILE

                    git config user.email "jenkins@localhost"
                    git config user.name "jenkins"

                    if git diff --quiet; then
                        echo "No changes detected"
                        exit 0
                    fi

                    git add "$FILE"
                    git commit -m "ci(helm): bump image tag to ${BUILD_NUMBER}"
                    git push origin main
                    '''
                }  
              
            }
        }
    }
       
    }
       
}